{
  "manifest_version": 3,
  "name": "Anime New Tab",
  "description": "Beautiful Anime Inspired New Tab",
  "version": "1.0",

  "permissions": ["storage", "bookmarks", "favicon", "scripting"],

  "chrome_url_overrides": {
    "newtab": "newTab.html"
  },

  "host_permissions": ["<all_urls>"],

  "web_accessible_resources": [
    {
      "resources": ["default.jpg"],
      "matches": ["<all_urls>"]
    }
  ]
}
