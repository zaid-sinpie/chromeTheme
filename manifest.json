{
  "manifest_version": 3,
  "name": "Anime New Tab",
  "description": "Beautiful Anime Inspired New Tab",
  "version": "1.0",

  "permissions": ["storage", "bookmarks", "favicon"],

  "chrome_url_overrides": {
    "newtab": "newTab.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["default.jpg"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
